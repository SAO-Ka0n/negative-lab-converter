    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
