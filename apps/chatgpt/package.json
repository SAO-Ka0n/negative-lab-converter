{
  "name": "@negative-lab/chatgpt-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ChatGPT App for Negative Lab Converter",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
